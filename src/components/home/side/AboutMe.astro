<style lang="scss">
    @use "/src/styles/variables.scss" as *;
    @use "/src/styles/mixins.scss" as *;
    .AboutMe {
        @include basePanel;
        padding: $base-spacing * 4;

        &__PictureContainer {
            height: 200px;
            width: 100%;
            overflow: hidden;
        }

        &__Name {
            margin-top: -1em;
            display: flex;
            justify-content: center;
            font-size: 3em;
            color: white;
            @include TextStroke(var(--accent-purple), 3px);
        }
    }
