---
import TranslatedSubscript from "../../shared/TranslatedSubscript.astro";
---

<section class="Welcome">
    <TranslatedSubscript translation="Welcome!" translationLang="en">
        <h2 lang="ja" aria-label="おかえりなさい! — Welcome!">
            <span class="TranslatedSubscript__Text">おかえりなさい!</span>
        </h2>
    </TranslatedSubscript>

    <p>Thanks for stopping by. <br />Would you like some tea?</p>
    <p>
        I really wanted to create my own space in the internet, <br /> inspired by
        <i>early WWW Japanese websites</i>.<br /> That's where you are now! <br
        />
    </p>
    <p>
        Feel free to explore the place. Take a look. Go where your interest
        takes you.
    </p>
</section>

<style lang="scss">
    @use "/src/styles/variables.scss" as *;
    @use "/src/styles/mixins.scss" as *;
    .Welcome {
        @include basePanel;
        padding: $base-spacing * 4;
        min-width: 21em;
    }
</style>
