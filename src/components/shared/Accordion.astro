---
interface Props {
    title: string;
    open?: boolean;
}

const { title, open = false } = Astro.props;
---

<details class="Accordeon" open={open}>
    <summary class="Accordeon__Summary">
        <span class="Accordeon__Title">{title}</span>
        <span class="Accordeon__Icon" aria-hidden="true">+</span>
    </summary>

    <div class="Accordeon__Body">
        <slot name="Body">
            <slot />
        </slot>
    </div>
</details>

<style lang="scss">
    @use "../../styles/mixins.scss" as Mixins;

    .Accordeon {
        overflow: clip;
        transition:
            border-color 180ms ease,
            box-shadow 180ms ease;

        &__Summary {
            padding: 0.25rem 1rem;
            margin-bottom: 0.25rem;
            border: 1px dashed white;
            border-radius: 0.5rem;
            box-shadow: 0 1px 5px rgba(0, 0, 0, 0.1);
            background-image: url(/public/backgrounds/StripePanelsPink.jpg);
            background-size: 2%;
            display: flex;
            align-items: center;
            font-size: 1.125rem;
            justify-content: space-between;
            gap: 1rem;
            cursor: pointer;
            color: white;
            font-weight: 600;
            list-style: none;
            @include Mixins.TextStroke(var(--accent-pink), 3px);

            &::-webkit-details-marker {
                display: none;
            }
        }

        &__Icon {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 1.25rem;
            height: 1.25rem;
            font-size: 1.125rem;
            line-height: 1;
            transition: transform 180ms ease;
            transform-origin: center;
        }

        &__Body {
            padding: 0 1rem 0.5rem;
            background: transparent;

            :global(*) {
                background: transparent;
            }
        }

        &[open] {
            .Accordeon__Icon {
                transform: rotate(45deg);
            }
        }
    }
</style>
