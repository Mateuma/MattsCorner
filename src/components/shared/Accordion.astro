---
interface Props {
    title: string;
    open?: boolean;
}

const { title, open = false } = Astro.props;
---

<details class="Accordion" open={open}>
    <summary class="AccordionSummary">
        <span class="AccordionTitle">{title}</span>
        <span class="AccordionIcon" aria-hidden="true">+</span>
    </summary>

    <div class="AccordionBody">
        <slot name="Body">
            <slot />
        </slot>
    </div>
</details>

<style>
    .Accordion {
        border: 1px solid var(--gray-light, #d6d6d6);
        border-radius: 0.5rem;
        overflow: clip;
    }

    .AccordionSummary {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        cursor: pointer;
        padding: 0.875rem 1rem;
        font-weight: 600;
        list-style: none;
    }

    .AccordionSummary::-webkit-details-marker {
        display: none;
    }

    .AccordionTitle {
        line-height: 1.25;
    }

    .AccordionIcon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.25rem;
        height: 1.25rem;
        font-size: 1.125rem;
        line-height: 1;
        transition: transform 180ms ease;
        transform-origin: center;
    }

    .AccordionBody {
        padding: 0 1rem 1rem;
        background: transparent;
    }

    .AccordionBody :global(*) {
        background: transparent;
    }

    .Accordion[open] .AccordionIcon {
        transform: rotate(45deg);
    }
</style>
